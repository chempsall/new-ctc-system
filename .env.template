# =============================================================================
# .env.template
# Copy this file to .env and fill in your values.
# The .env file is listed in .gitignore and is NEVER committed to git.
#
# To use:
#   Windows:  copy .env.template .env   (then edit .env)
#   Mac/Linux: cp .env.template .env    (then edit .env)
# =============================================================================

# ---------------------------------------------------------------------------
# Environment: development | beta | production
# ---------------------------------------------------------------------------
RF_ENV=development

# ---------------------------------------------------------------------------
# File paths
# Defaults point to the source-data folder relative to the project root.
# Only set these if your files are somewhere other than source-data/.
# ---------------------------------------------------------------------------
# RF_STAFF_LIST_PATH=C:\Users\you\Dev\new-ctc-system\source-data\UK010117_Staff_List.xlsx
# RF_PAR_ACTUALS_PATH=C:\Users\you\Dev\new-ctc-system\source-data

# ---------------------------------------------------------------------------
# PAR source
# RF_PAR_USE_SHAREPOINT=false  reads local UK_PAR*.xlsx from source-data/
# RF_PAR_USE_SHAREPOINT=true   connects directly to SharePoint (requires SP credentials)
# ---------------------------------------------------------------------------
RF_PAR_USE_SHAREPOINT=false

# ---------------------------------------------------------------------------
# Security
# Required in beta and production. Optional in development.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# ---------------------------------------------------------------------------
RF_ADMIN_TOKEN=
RF_SECRET_KEY=dev-secret-change-in-production

# ---------------------------------------------------------------------------
# Flask server
# Change RF_HOST to 0.0.0.0 when deploying to a server.
# ---------------------------------------------------------------------------
RF_HOST=127.0.0.1
RF_PORT=5000
RF_DEBUG=true

# ---------------------------------------------------------------------------
# Scheduler — time to run the nightly import (24-hour, server local time)
# ---------------------------------------------------------------------------
RF_SCHEDULER_HOUR=8
RF_SCHEDULER_MINUTE=0

# ---------------------------------------------------------------------------
# SharePoint — only needed when RF_PAR_USE_SHAREPOINT=true
# ---------------------------------------------------------------------------
RF_SP_TENANT_ID=
RF_SP_CLIENT_ID=
RF_SP_CLIENT_SECRET=
RF_SP_SITE_URL=
