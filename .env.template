# =============================================================================
# .env.template
# Copy this file to .env and fill in your values.
# The .env file is listed in .gitignore and is NEVER committed to git.
# This template IS committed — it documents what settings exist.
#
# To use:
#   Windows:  copy .env.template .env   (then edit .env)
#   Mac/Linux: cp .env.template .env    (then edit .env)
#
# The app loads .env automatically if python-dotenv is installed.
# Install it with: pip install python-dotenv
# =============================================================================

# ---------------------------------------------------------------------------
# Environment: development | beta | production
# ---------------------------------------------------------------------------
RF_ENV=development

# ---------------------------------------------------------------------------
# Paths
# Set these to match your machine / server.
#
# Development (Chris's machine):
#   RF_STAFF_LIST_PATH=C:\Users\UKCMH001\Dev\new-ctc-system\source-data\UK010117_Staff_List.xlsx
#
# Beta (shared server):
#   RF_STAFF_LIST_PATH=/srv/new-ctc-system/source-data/UK010117_Staff_List.xlsx
#
# Production (employer-hosted, SharePoint sync):
#   RF_STAFF_LIST_PATH=C:\SharePoint\new-ctc-system\source-data\UK010117_Staff_List.xlsx
# ---------------------------------------------------------------------------
# ---------------------------------------------------------------------------
# PAR actuals source
#
# RF_PAR_USE_SHAREPOINT=false (testing):
#   Reads the most recent UK_PAR*.xlsx file from the source-data folder.
#   Download yesterday's PAR file from SharePoint and place it there.
#   Filename must start with YYYYMM e.g. 202604_UK_PAR_Active.xlsx
#
# RF_PAR_USE_SHAREPOINT=true (production):
#   Fetches directly from SharePoint using Microsoft Graph.
#   Requires SP credentials below to be set.
#   RF_PAR_ACTUALS_PATH is ignored in this mode.
# ---------------------------------------------------------------------------
RF_PAR_USE_SHAREPOINT=false
RF_PAR_ACTUALS_PATH=C:\Users\UKCMH001\Dev\new-ctc-system\source-data

# ---------------------------------------------------------------------------
# Security
# Required in beta and production. Optional in development.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# ---------------------------------------------------------------------------
RF_ADMIN_TOKEN=
RF_SECRET_KEY=dev-secret-change-in-production

# ---------------------------------------------------------------------------
# Flask server
# Change RF_HOST to 0.0.0.0 when deploying to a server so it accepts
# connections from other machines on the network.
# ---------------------------------------------------------------------------
RF_HOST=127.0.0.1
RF_PORT=5000
RF_DEBUG=true

# ---------------------------------------------------------------------------
# Scheduler — time to run the nightly import (24-hour, server local time)
# ---------------------------------------------------------------------------
RF_SCHEDULER_HOUR=8
RF_SCHEDULER_MINUTE=0

# ---------------------------------------------------------------------------
# SharePoint — leave blank in development
# Fill in when the employer hosts this and SharePoint integration is set up.
# ---------------------------------------------------------------------------
RF_SP_TENANT_ID=
RF_SP_CLIENT_ID=
RF_SP_CLIENT_SECRET=
RF_SP_SITE_URL=