# =============================================================================
# .gitignore
# Files that must never be committed to git.
# =============================================================================

# ---------------------------------------------------------------------------
# Secrets and local configuration — NEVER commit these
# ---------------------------------------------------------------------------
.env
*.env
logs/

# ---------------------------------------------------------------------------
# Database files — contain real staff and project data
# ---------------------------------------------------------------------------
data/*.db
data/*.db-shm
data/*.db-wal

# ---------------------------------------------------------------------------
# Source Data — raw WSP data which must never be committed (readme file explains)
# ---------------------------------------------------------------------------
source-data/*.*
source-data/**/*
!source-data/readme.md

# ---------------------------------------------------------------------------
# Resource to Complete — test/live CTC files. Real allocation data, must
# never be committed. Will move to SharePoint eventually, but excluded
# here regardless in case it's ever used locally again.
# ---------------------------------------------------------------------------
Resource to Complete/

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg
venv/
env/
.venv/
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage
htmlcov/
.pytest_cache/

# ---------------------------------------------------------------------------
# OS and editor files
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
logs/